generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PostSource {
  SCRAPING
  DISPATCHER
}

model LogisticMessage {
  id                Int       @id @default(autoincrement())
  tgMessageId       Int       // Telegram xabar ID
  channelName       String
  text              String
  date              DateTime?
  views             Int?

  // Bitta uzun Telegram habardan bir nechta yuk ajratib olinganda,
  // har bir yuk alohida row sifatida saqlanadi. blockIndex shu bo'lakning
  // habar ichidagi tartib raqami (0 = birinchi yuk, 1 = ikkinchi, ...).
  // Qisqa habarlarda (oddiy bitta yuk) blockIndex = 0.
  blockIndex        Int        @default(0)

  aiStatus          String     // "LOAD_POST" | "REGULAR_MESSAGE"
  structured        Json?
  normalized        Json?

  countryFrom       String?
  countryTo         String?
  regionFrom        String?
  regionTo          String?

  title             String?
  weight            Float?
  cargoUnit         String?
  vehicleType       String?
  paymentType       String?
  paymentAmount     Float?
  advancePayment    Float?
  paymentCurrency   String?
  pickupDate        DateTime?
  phoneNumber       String?

  sentToTelegramAt  DateTime?
  isComplete        Boolean @default(false)

  source            PostSource @default(SCRAPING)
  createdById       Int?
  createdBy         User?      @relation(fields: [createdById], references: [id], onDelete: SetNull)

  isActual          Boolean    @default(true) // xabar yangimi yoki yo‘qmi
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  // NOTE: No DB-level unique constraint on (tgMessageId, channelName,
  // blockIndex). Application-level dedup in PostsService.create
  // (findFirst by tgMessageId+channelName) is the source of truth.
  // Reason: dispatcher posts all share the sentinel pair
  // (tgMessageId=0, channelName='DISPATCHER') by design, which would
  // collide with any unique constraint covering those columns.
  @@index([source])
  @@index([createdById])
  @@index([tgMessageId, channelName])
}

model TelegramGroup {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  title     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id          Int       @id @default(autoincrement())
  fullName    String?
  username    String?   @unique
  phone       String?   @unique
  password    String?
  role        UserRole  @default(DISPATCHER)
  isActive    Boolean   @default(true)
  paymentKey  String?
  paymentDate DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  posts       LogisticMessage[]
}

enum UserRole {
  ADMIN
  DISPATCHER
}

enum VerificationPurpose {
  REGISTER
  RESET_PASSWORD
}

model VerificationCode {
  id            Int                 @id @default(autoincrement())
  phone         String
  codeHash      String
  purpose       VerificationPurpose
  attemptsLeft  Int                 @default(3)
  expiresAt     DateTime
  consumedAt    DateTime?
  createdAt     DateTime            @default(now())

  @@index([phone, purpose])
}
